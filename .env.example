# Swordbot API Usage - Configuration
# Copy to .env and fill in real values

# Server
PORT=4747
DATA_DIR=./data

# Provider API keys (only set the ones you use)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# DEMO_MODE=true forces synthetic data even when real keys are set.
# Useful for screenshots and demos.
DEMO_MODE=false

# Notifications (Slack webhook URL — leave blank to disable)
SLACK_WEBHOOK_URL=

# Polling cadence (cron expression). Default = every 15 min.
POLL_CRON=*/15 * * * *

# Budgets (USD/month). 0 disables.
BUDGET_GOOGLE=0
BUDGET_OPENAI=0
BUDGET_ANTHROPIC=0

# Alert thresholds (% of budget) — comma-separated
ALERT_THRESHOLDS=50,75,90,100
